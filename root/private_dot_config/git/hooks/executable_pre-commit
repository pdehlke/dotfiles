#!/usr/bin/env bash
set -euo pipefail

# Chain to any project-local pre-commit hook that predates this global one.
# core.hooksPath replaces .git/hooks entirely, so local hooks won't run
# unless we call them explicitly.
local_hook="$(git rev-parse --git-dir)/hooks/pre-commit"
if [[ -x "$local_hook" ]]; then
	"$local_hook"
fi

if ! command -v trufflehog >/dev/null 2>&1; then
	echo "trufflehog not found, cannot scan for secrets"
	exit 128
fi

# Tell trufflehog we're running in pre-commit mode
export TRUFFLEHOG_PRE_COMMIT=1

trufflehog git file://. \
	--results=verified,unverified \
	--filter-unverified \
	--no-update \
	--fail
