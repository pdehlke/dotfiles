#!/usr/bin/env bash
set -euo pipefail

# Chain to any project-local pre-commit hook that predates this global one.
# core.hooksPath replaces .git/hooks entirely, so local hooks won't run
# unless we call them explicitly.
local_hook="$(git rev-parse --git-dir)/hooks/pre-commit"
if [[ -x "$local_hook" ]]; then
	"$local_hook"
fi

if ! command -v gitleaks &>/dev/null; then
	echo "gitleaks not installed. Install: https://github.com/gitleaks/gitleaks" >&2
	exit 1
fi

gitleaks protect --staged --redact --exit-code 1 --verbose
