[tools]
gh = "2.92.0"
ghq = "1.10.1"
jq = "1.8.1"
just = "1.50.0"
{{ if not .isContainer }}
# These four combine for nearly 1 GB in docker. Only install them if we're not in a container.
node = "24"
java = "21"
opentofu = "1.12.3"
aws-cli = { version = "2.35.9", symlink_bins = "true" }
{{ end }}
peco = "0.6.0"
python = "3"
shfmt = "3.13.1"
yq = "4.53.2"
popeye = "0.22.1"
conftest = "0.68.2"
# maven = "latest"
uv = "0.11.10"

[settings]
experimental = true
color_theme = "catpucchin"
java.shorthand_vendor = "temurin"
legacy_version_file = true
idiomatic_version_file_enable_tools = ["python", "node", "java"]
python.github_attestations = true
python.uv_venv_auto = true
locked = true

# ==> Pin versions of tools to specifics for faster switches and specific versions for projects

# Node versionss
[tool_alias.node.versions]
18 = "18.20.8"
20 = "20.18.3"
22 = "22.22.0"
24 = "24.13.0"

# Java versions
[tool_alias.java.versions]
11 = "11.0.30+7"
17 = "17.0.18+8"
21 = "21.0.10+7.0.LTS"
25 = "25.0.2+10.0.LTS"

# Python versions
[tool_alias.python.versions]
3 = "3.14.3"
2 = "2.7.18"

[hooks]
enter = "mise env | grep -vE 'JAVA|PATH' | sed s/export/mise:\\ setting/g"
