{{- /*
# vim:ft=sh.gotmpl:
    */ -}}

{{- if (eq .chezmoi.os "linux" "android" "darwin") -}}

  {{-   if eq .chezmoi.os "android" -}}
#!/bin/sh
  {{-   else -}}
#!/usr/bin/env bash
  {{-   end }}

# -e: exit on error
set -e

{{    if eq .chezmoi.os "android" -}}
chsh -s zsh
{{-   else if eq .chezmoi.os "linux" -}}
chsh --shell /bin/zsh
{{-   end }}

{{- if lookPath "subl" }}
#subl --command "install_package_control"
{{- end }}

{{- if lookPath "vim" }}
vim  -i NONE -c 'PlugClean!' -c 'PlugInstall!' -c 'qa'
{{- end }}

{{- end }}
