#!/usr/bin/env zsh
# Add a file to the private dotfiles repo.
# Usage: chezmoi-add [-p|--plain] <file> [<file> ...]
#
# By default adds with age encryption (requires op CLI signed in).
# Use -p/--plain to add without encryption (for private but non-secret files).
#
# Delegates to pchezmoi for key management and config setup.
setopt ERR_EXIT NO_UNSET PIPE_FAIL PROMPT_SUBST
PS4='+(%x:%I): ${funcstack[1]:+${funcstack[1]}(): }'

source "${HOME}/.zsh.after/000_functions.zsh"

PLAIN=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--plain) PLAIN=true; shift ;;
    --) shift; break ;;
    *) break ;;
  esac
done

if [[ "$#" -eq 0 ]]; then
  log FATAL "Usage: $(basename "$0") [-p|--plain] <file> [<file> ...]"
fi

if "$PLAIN"; then
  pchezmoi add --no-pager --verbose "$@" || log FATAL "chezmoi add failed"
else
  pchezmoi add --no-pager --verbose --encrypt "$@" || log FATAL "chezmoi add failed"
fi
